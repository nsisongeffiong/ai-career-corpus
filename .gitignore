# A FILLED corpus must never be pushed to a public remote.
# These patterns are a seatbelt, not a substitute for keeping your filled copy private.
# Run scripts/validate_corpus.py before committing a filled corpus.

# Job descriptions and per-application outputs
Job Description.md
Per-Application/
Pipeline/
Applications*/
exports/

# Rendered artifacts and binary documents (voice samples, generated resumes)
*.docx
*.pdf

# Data exports and spreadsheets that may carry personal data
*.xlsx
*.csv
*.jsonl
*.zip

# Images / screenshots
*.png
*.jpg
*.jpeg

# Secrets and local config
.env
.env.*
*.key
*.pem
*.pfx
private-terms.txt

# Local agent settings (bundled skills in .claude/skills/ DO ship)
.claude/*
!.claude/skills/

# Tooling and OS noise
__pycache__/
.venv/
node_modules/
.DS_Store
Thumbs.db
